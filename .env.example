# GitHub Personal Access Token (for local testing)
# When running in GitHub Actions, this is automatically provided
GITHUB_TOKEN=ghp_your_github_token_here

# Anthropic API Key for Claude
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# GitHub Repository (format: owner/repo)
# Only needed for local testing, automatically set in GitHub Actions
GITHUB_REPOSITORY=owner/repo

# Pull Request Number (for local testing only)
PR_NUMBER=1
