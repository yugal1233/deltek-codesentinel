{
  "name": "deltek-codesentinel",
  "version": "1.0.0",
  "description": "Deltek CodeSentinel - AI-powered code review bot using Claude API for GitHub pull requests",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "ts-node src/testRunner.ts",
    "test:build": "npm run build && node dist/testRunner.js",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude",
    "github",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@octokit/rest": "^21.0.2",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
